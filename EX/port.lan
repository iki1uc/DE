[lan0]
version = 1.0
type = "route-kernel"
zero = 0

# LAN‑Achsen (Routing)
lan.axis = ["X","Y","Z"]
lan.vector = ["6d0","12e0","6e0"]

# LAN‑Zonen (EPOCHE)
lan.zone.X = [0,1,2, 9,10,11, 18,19,20]
lan.zone.Y = [27,28,29, 36,37,38, 45,46,47]
lan.zone.Z = [54,55,56, 63,64,65, 72,73,74]

# Routing‑Regel
lan.rule = "Leitet Zustände zwischen EPOCHE, RAUM und EX weiter"

# Bindungen
lan.bind.matrix = "matrix9x9"
lan.bind.room   = "port.room"
lan.bind.ex     = "EX"
lan.bind.sli    = "SLI.layer"
