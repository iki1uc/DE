if(input === "4u"){
  activeRoutes = ["TR","EN"];
}
function multi(gen, times){
  return Array(times).fill(gen);
}
async function autoComplete(gen){
  const chain = multi(gen,2); // Quadrat-Modus
  for(const g of chain){
    await runMorph("PQ", g);
  }
  finalizeTask(gen);
}

